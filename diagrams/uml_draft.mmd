classDiagram
    class Owner {
        +int owner_id
        +str name
        +int available_minutes
        +time window_start
        +list~Pet~ pets
        +add_pet(pet) None
        +edit_pet(pet_id, fields) None
        +list_pets() list~Pet~
        +all_tasks() list~Task~
    }
    class Pet {
        +int pet_id
        +str name
        +str species
        +int owner_id
        +list~Task~ tasks
        +add_task(task) None
        +edit_task(task_id, fields) None
        +get_tasks() list~Task~
    }
    class Task {
        +int task_id
        +int pet_id
        +str name
        +int duration
        +Priority priority
        +edit(fields) None
    }
    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }
    class Scheduler {
        +Owner owner
        +generate_schedule() Schedule
        +format_schedule() str
    }
    class Placement {
        +Task task
        +time start_time
        +time end_time
    }
    class Schedule {
        +list~Placement~ scheduled
        +list~Task~ inapplicable
    }

    Owner "1" *-- "0..*" Pet : owns
    Pet "1" *-- "0..*" Task : has
    Schedule "1" *-- "0..*" Placement : contains
    Scheduler "1" --> "1" Owner : schedules for
    Scheduler ..> Schedule : returns
    Schedule "1" --> "0..*" Task : inapplicable
    Placement "0..1" --> "1" Task : wraps
    Task ..> Priority